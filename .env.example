# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@ep-xxxxx.region.aws.neon.tech/dbname?sslmode=require

# LLM API key (choose one)
OLLAMA_API_KEY=ollama
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter (for cross-model eval and cost attribution)
OPENROUTER_API_KEY=sk-or-v1-...

# Pipeline overrides (optional, set per-run via command line)
# PIPELINE_MODEL=openai:qwen/qwen3.5-9b
# OPENROUTER_RUN_TAG=R08
# OPENROUTER_PROVIDER={"sort":"latency"}

# Logging
LOG_FILES_DIR_PATH=logs
LOG_FILE_NAME=text_to_sql.log
USAGE_LOG_FILE_NAME=token_usage.jsonl
